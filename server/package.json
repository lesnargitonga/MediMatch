{
  "name": "medimatch-server",
  "version": "0.1.0",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "migrate": "node dist/tools/migrate.js",
    "bootstrap:admin": "node dist/tools/bootstrapAdmin.js",
    "db:reset": "node dist/tools/resetDb.js",
    "reset:db": "ts-node src/tools/resetDb.ts",
    "db:inspect": "node dist/tools/inspectDb.js",
    "db:inspect:file": "cross-env USE_FILE_DB=true node dist/tools/inspectDb.js",
    "db:inspect:mock": "cross-env USE_MOCK_DB=true node dist/tools/inspectDb.js",
    "db:import:file": "node dist/tools/importFromFileDb.js",
    "db:seed": "npm run build && node dist/tools/migrate.js && node dist/tools/seed.js"
  ,"admin:bootstrap": "npm run build && node dist/tools/bootstrapAdmin.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "medimatch": "file:..",
    "pg": "^8.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.17",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^2.0.12",
    "cross-env": "^10.1.0",
    "supertest": "^6.3.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.0.0"
  }
}
