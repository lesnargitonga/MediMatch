# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Database mode (pick one) ─────────────────────────────────────────────────
# USE_MOCK_DB=true        # In-memory seed data — no setup required
# USE_FILE_DB=true        # JSON file at server/data/filedb.json
# (leave both unset)      # Postgres / PostGIS (requires DATABASE_URL below)

# ─── Postgres ─────────────────────────────────────────────────────────────────
# DATABASE_URL=postgres://user:password@localhost:5432/medimatch

# ─── Dev helpers ──────────────────────────────────────────────────────────────
# DISABLE_RATE_LIMIT=true
